# 常见压缩包格式（Git 忽略规则）
# ZIP 系列（含分卷/特殊格式）
*.zip
*.zipx
*.7z
*.7z.001  # 7z分卷压缩包

# RAR 系列（含分卷/未完成）
*.rar
*.r00
*.r01
*.r99     # RAR分卷压缩包
*.rar.part # 未完成的RAR压缩包

# Unix/Linux/macOS 归档+压缩
*.tar     # 纯归档（未压缩）
*.tar.gz  # tar + gzip
*.tgz     # tar.gz 的简写
*.tar.bz2 # tar + bzip2
*.tbz2    # tar.bz2 的简写
*.tar.xz  # tar + xz
*.txz     # tar.xz 的简写
*.gz      # 单独gzip压缩
*.bz2     # 单独bzip2压缩
*.xz      # 单独xz压缩
*.lzma    # lzma压缩
*.lz      # lz压缩

# 系统/安装包类压缩格式
*.cab     # Windows 压缩包
*.iso     # 光盘镜像
*.img     # 磁盘镜像
*.dmg     # macOS 镜像
*.pkg     # macOS 安装包
*.deb     # Debian/Ubuntu 安装包
*.rpm     # CentOS/RHEL 安装包
*.msi     # Windows 安装包

# 开发相关归档包（本质是压缩包）
*.jar     # Java 归档包
*.war     # Java Web 归档包
*.ear     # Java EE 归档包
*.apk     # Android 安装包（底层是ZIP）
*.ipa     # iOS 安装包（底层是ZIP）

tmp/
/temporary/